{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",

    /* Strict mode */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["docs/.vitepress/*"],
      "@theme/*": ["docs/.vitepress/theme/*"],
      "@components/*": ["docs/.vitepress/theme/components/*"],
      "@composables/*": ["docs/.vitepress/theme/composables/*"],
      "@services/*": ["docs/.vitepress/theme/services/*"],
      "@styles/*": ["docs/.vitepress/theme/styles/*"],
      "@types/*": ["docs/.vitepress/theme/types/*"]
    }
  },
  "include": [
    "docs/.vitepress/**/*.ts",
    "docs/.vitepress/**/*.vue",
    "docs/.vitepress/env.d.ts"
  ],
  "exclude": ["node_modules", "docs/.vitepress/cache", "docs/.vitepress/dist"]
}
